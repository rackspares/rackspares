# RackSpares environment configuration
# Copy this file to .env and fill in real values before starting.
# .env is git-ignored; never commit secrets.

# ── Required ──────────────────────────────────────────────────────────────────

# JWT signing key AND encryption key for stored credentials.
# Must be at least 32 random characters. Must not contain common words.
# Generate a strong value with:
#   openssl rand -hex 32
SECRET_KEY=

# ── Authentication ────────────────────────────────────────────────────────────

# Credentials for the seeded admin account (created on first startup).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Database ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://rackspares:rackspares@db:5432/rackspares

# ── CORS ─────────────────────────────────────────────────────────────────────
#
# Comma-separated list of browser origins that may call the API.
# Include every URL your users access the frontend from.
# Examples:
#   Single origin:    ALLOWED_ORIGINS=https://rackspares.example.com
#   Multiple origins: ALLOWED_ORIGINS=https://rackspares.example.com,https://rackspares-staging.example.com
#   Local dev:        ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000

# ── File storage ──────────────────────────────────────────────────────────────

UPLOAD_DIR=/app/uploads
